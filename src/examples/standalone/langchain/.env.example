# ===============================
# 🔑 Wallet & Blockchain Settings
# ===============================

# Your private key for the wallet (must be 64 hex chars with or without 0x prefix)
# Example: 0xabcdef1234... (never share this in public repos!)
# This is required for blockchain transactions and wallet operations
PRIVATE_KEY=

# ChainId identifier. Should match the configId passed to BOSON_MCP_URL when prompting the AI.
# Example for Base Sepolia on staging environment: configId: staging-84532-0, chainId: 84532
CHAIN_ID=84532

# ===============================
# 🤖 AI / Anthropic Settings
# ===============================

# Anthropic API key for Claude models.
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=


# ===============================
# 🛠 MCP Server Config
# ===============================

# For testing with staging MCP server
BOSON_MCP_URL=https://mcp-staging.bosonprotocol.io/mcp
# or this url for production
# BOSON_MCP_URL=https://mcp.bosonprotocol.io/mcp

