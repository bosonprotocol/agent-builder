# ===============================
# 🔑 Wallet & Blockchain Settings
# ===============================

# Your private key for the wallet (must be 64 hex chars prefixed with 0x).
# Example: 0xabcdef1234... (never share this in public repos!)
# Used in src/vercel/index.ts
PRIVATE_KEY=


# ===============================
# 🤖 AI / Anthropic Settings
# ===============================

# Anthropic API key for Claude models.
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===============================
# 🛠 Boson MCP Server Config
# ===============================

# For testing with staging MCP server
BOSON_MCP_URL=https://boson-mcp-server-staging-170470978472.europe-west2.run.app/mcp
# or this url for production
# BOSON_MCP_URL=https://boson-mcp-server-production-170470978472.europe-west2.run.app/mcp


# ===============================
# 📧 Email MCP Server Config
# ===============================
# We’ll be launching the Email MCP Server locally,
# but you’ll first need to set it up on Google Cloud
# so that we can send emails.
#
# The full Google Cloud setup and remaining configuration
# steps are documented in the repository:
# https://github.com/GongRzhe/Gmail-MCP-Server/tree/main
#
# Generate your authentication key here:
# https://smithery.ai/server/@gongrzhe/server-gmail-autoauth-mcp
# (Log in and generate a key, then paste it below)

SMITHERY_GMAIL_KEY=

