{
  "name": "agent-builder",
  "version": "1.0.0",
  "main": "eslint.config.js",
  "scripts": {
    "start:vercel-agent": "npx cross-env NODE_ENV=production node -r dotenv/config src/vercel/index.ts",
    "start:telegram-bot-agent": "npx cross-env NODE_ENV=production node -r dotenv/config src/vercel/telegram.ts",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
